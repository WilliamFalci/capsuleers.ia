# --- Infrastruttura ---
QDRANT_PORT=6333
OLLAMA_PORT=11434
API_PORT=3000

# --- Endpoint servizi (host visti da API e ingestion) ---
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434

# --- Modelli ---
LLM_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# --- Qdrant ---
QDRANT_COLLECTION=eve_knowledge

# --- RAG ---
RETRIEVAL_TOP_K=8
MAX_CONTEXT_CHARS=8000

# --- API ---
CORS_ORIGIN=*
SESSION_TTL_SECONDS=3600
