[Unit]
Description=Daily EVE University wiki update for Capsuleers.IA

[Timer]
# Every day at 11:30 (offset from the SDE timer at 11:00 so they don't overlap).
# Persistent catches up the run if the machine was off.
OnCalendar=*-*-* 11:30:00
RandomizedDelaySec=1800
Persistent=true

[Install]
WantedBy=timers.target
