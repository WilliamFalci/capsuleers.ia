{
  "name": "capsuleers-ia-desktop",
  "version": "0.1.1",
  "description": "Capsuleers.IA — app desktop standalone (multipiattaforma, GPU via Vulkan/Metal/CUDA)",
  "type": "module",
  "main": "src/main.mjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build-index": "node build-index.mjs",
    "export-index": "python3 export_index.py",
    "rag": "node rag.mjs",
    "validate-hf": "node tools/validate-hf.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-llama-cpp": "^3.18.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
